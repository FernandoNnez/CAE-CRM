@{
    ViewData["Title"] = "Acceso Denegado";
}

<div style="max-width: 600px; margin: 80px auto; text-align: center; background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-top: 5px solid #dc3545;">
    
    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 20px;">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>

    <h1 style="color: #333; margin-top: 0;">Conflicto de Permisos</h1>
    <p style="color: #666; font-size: 16px; line-height: 1.6; margin-bottom: 30px;">
        Tu cuenta actual tiene el rol de <strong>Usuario Estándar</strong>. Esta acción (como dar de baja o rehabilitar equipos) requiere privilegios de <strong>Administrador</strong>.
    </p>

    <div style="background-color: #f8f9fa; padding: 15px; border-radius: 6px; border-left: 4px solid #d59f0f; text-align: left; margin-bottom: 30px; font-size: 14px; color: #555;">
        Si crees que esto es un error o necesitas realizar esta acción, por favor contacta al administrador del sistema CAE.
    </div>

    <a href="javascript:history.back()" style="background-color: #002b5c; color: white; padding: 10px 25px; text-decoration: none; border-radius: 4px; font-weight: bold; display: inline-block;">
        Regresar a la página anterior
    </a>
</div>
