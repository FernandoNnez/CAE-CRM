@model CAE_CRM.Models.Login.LoginModel
@{
    ViewData["Title"] = "Acceso - CAE CRM";
    Layout = null;
}

<style>
    :root {
        --unam-blue: #002b5c;
        --unam-gold: #d59f0f;
        --text-color: #333333;
    }

    body, html {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        position: relative;
        overflow: hidden;
    }

        .login-container::before {
            content: "";
            position: absolute;
            top: -20px;
            left: -20px;
            right: -20px;
            bottom: -20px;
            background-image: url('https://www.aragon.unam.mx/orientafest/src/images/logos/logos-unam-fes-aragon.png');
            background-size: cover;
            background-position: center;
            filter: blur(8px) brightness(0.6);
            z-index: -1;
        }

    .login-card {
        background: #ffffff;
        width: 100%;
        max-width: 400px;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        border-top: 5px solid var(--unam-gold);
        z-index: 1;
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .login-header h2 {
            color: var(--unam-blue);
            font-weight: 600;
            margin: 0;
            font-size: 24px;
        }

        .login-header p {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-color);
            font-weight: 500;
            font-size: 14px;
        }

    /* NUEVO: Contenedor para la contraseña y el ícono */
    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 14px;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
        box-sizing: border-box;
    }

    /* NUEVO: Damos espacio a la derecha para que el texto no pise el ícono */
    .password-wrapper .form-control {
        padding-right: 40px;
    }

    .form-control:focus {
        border-color: var(--unam-blue);
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 43, 92, 0.1);
    }

    /* NUEVO: Estilo para el botón de mostrar/ocultar */
    .btn-toggle-password {
        position: absolute;
        right: 10px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #888;
        transition: color 0.2s ease;
    }

        .btn-toggle-password:hover {
            color: var(--unam-blue);
        }

        .btn-toggle-password:focus {
            outline: none;
        }

        .btn-toggle-password svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

    .btn-login {
        width: 100%;
        padding: 12px;
        background-color: var(--unam-blue);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.1s ease;
        margin-top: 10px;
    }

        .btn-login:hover {
            background-color: #001f42;
        }

        .btn-login:active {
            transform: scale(0.98);
        }

    .alert-error {
        color: #842029;
        background-color: #f8d7da;
        border: 1px solid #f5c2c7;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-size: 14px;
        text-align: center;
    }

    .text-danger {
        color: #dc3545;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>CAE CRM</h2>
            <p>Gestión de Inventario para equipo CAE</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label asp-for="User">Usuario</label>
                <input asp-for="User" class="form-control" placeholder="Ingresa tu usuario" autocomplete="username" />
                <span asp-validation-for="User" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Contraseña</label>
                <div class="password-wrapper">
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    
                    <!-- Botón para alternar visibilidad -->
                    <button type="button" class="btn-toggle-password" id="togglePassword" tabindex="-1" title="Mostrar contraseña">
                        <!-- Ícono inicial: Ojo cerrado -->
                        <svg viewBox="0 0 24 24" id="eyeIcon">
                            <path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"></path>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">
                Iniciar Sesión
            </button>
        </form>
    </div>
    <script src="~/Scripts/Login/Login-Handler.js" asp-append-version="true"></script>
</div>
