@model IEnumerable<CAE_CRM.Models.Users.UserListModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="color: #002b5c; margin: 0;">Gestión de Usuarios</h2>
        <a asp-action="Create" style="background-color: #002b5c; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px; font-weight: bold;">+ Nuevo Usuario</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div style="background: #f8d7da; color: #842029; padding: 12px; border-radius: 4px; margin-bottom: 15px;">
            @TempData["Error"]
        </div>
    }

    <table style="width: 100%; border-collapse: collapse; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <thead>
            <tr style="background-color: #f4f7f6; border-bottom: 2px solid #d59f0f;">
                <th style="padding: 12px; text-align: left;">Usuario</th>
                <th style="padding: 12px; text-align: left;">Rol</th>
                <th style="padding: 12px; text-align: left;">Estado</th>
                <th style="padding: 12px; text-align: left;">Último Acceso</th>
                <th style="padding: 12px; text-align: center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 12px; font-weight: bold;">@item.User</td>
                    <td style="padding: 12px;">@item.Role</td>
                    <td style="padding: 12px;">
                        @if (item.Active)
                        {
                            <span style="background-color: #d4edda; color: #155724; padding: 4px 8px; border-radius: 12px; font-size: 12px;">Activo</span>
                        }
                        else
                        {
                            <span style="background-color: #f8d7da; color: #721c24; padding: 4px 8px; border-radius: 12px; font-size: 12px;">Inactivo</span>
                        }
                    </td>
                    <td style="padding: 12px; color: #666;">@(item.LastLoginDate?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</td>
                    <td style="padding: 12px; text-align: center;">
                        <a asp-action="Edit" asp-route-id="@item.ID" style="color: #002b5c; text-decoration: none; margin-right: 15px; font-weight: bold;">Editar</a>
                        
                        @if (item.Active)
                        {
                            <form asp-action="Delete" asp-route-id="@item.ID" method="post" style="display:inline;" onsubmit="return confirm('¿Estás seguro de dar de baja a este usuario?');">
                                <button type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer; font-weight: bold; padding: 0;">Baja</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
